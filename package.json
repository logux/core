{
  "name": "@logux/core",
  "version": "0.10.0",
  "description": "Logux core components",
  "keywords": [
    "logux",
    "core",
    "connection",
    "websocket",
    "crdt",
    "event sourcing",
    "distributed systems"
  ],
  "scripts": {
    "test:coverage": "bnt --coverage 100 --coverage-exclude '**/*.test.*' --coverage-exclude 'test/*'",
    "test:lint": "eslint .",
    "test:types": "check-dts",
    "test": "pnpm run /^test:/"
  },
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "license": "MIT",
  "homepage": "https://logux.org/",
  "repository": "logux/core",
  "sideEffects": false,
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^22.0.0 || >=24.0.0"
  },
  "dependencies": {
    "nanoevents": "^9.1.0"
  },
  "devDependencies": {
    "@logux/eslint-config": "^57.1.0",
    "@types/ws": "^8.18.1",
    "actions-up": "^1.12.0",
    "better-node-test": "^0.8.3",

    "check-dts": "^1.0.0",
    "clean-publish": "^6.0.4",
    "eslint": "^10.1.0",
    "nanodelay": "^2.0.2",
    "nanospy": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ws": "^8.20.0"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  }
}
